# === The Factory v2 - environment template ===
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. On Render, set these in Dashboard > Environment.

# --- LLM keys (CSV, no spaces around commas) ---
GEMINI_API_KEYS=AIzaSy_xxx,AIzaSy_yyy
GROQ_API_KEYS=gsk_xxx,gsk_yyy,gsk_zzz

# --- Wallet (Solana / Phantom) ---
CHAIN=solana
WALLET_ADDRESS=7Mby3eZUCxuRkYd3gL89HyVciYaGqKLKQ26jDsLXzi6Q
# The private key is NOT needed server-side.

# --- Pricing (per-endpoint, in USD) ---
PRICE_METEO=0.01
PRICE_FX=0.02
PRICE_TRANSIT=0.02
PRICE_NEWS=0.02
PRICE_STOCKS=0.05
PRICE_GITHUB_STATS=0.02

# --- Bulk pricing (10-call pack, discounted) ---
BULK_PACK_SIZE=10
BULK_PACK_PRICE_USD=0.08
BULK_TOKEN_TTL_SECONDS=86400

# --- Subscription (monthly prepay) ---
SUBSCRIPTION_PRICE_USD=50.0
SUBSCRIPTION_QUOTA_CALLS=10000
SUBSCRIPTION_TOKEN_TTL_SECONDS=2592000

# --- Ethical cap (rolling 30-day) ---
MONTHLY_CAP_USD=120

# --- Solana public RPCs (rotated, free, no API key) ---
SOLANA_RPC_URLS=https://api.mainnet-beta.solana.com,https://solana-rpc.publicnode.com,https://rpc.ankr.com/solana
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# --- Cache (Upstash Redis REST, free, no card) ---
# Strongly recommended: caches identical LLM-cleaned responses for 1h,
# cutting LLM costs and serving more clients with same free-tier quota.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CACHE_TTL_SECONDS=3600

# --- Misc ---
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=20
PAYMENT_WINDOW_SECONDS=300
